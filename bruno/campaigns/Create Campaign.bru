meta {
  name: Create Campaign
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/campaigns
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Campaign",
    "description": "A test campaign"
  }
}

script:post-response {
  if (res.body.campaignId) {
    bru.setVar("campaignId", res.body.campaignId);
  }
}
